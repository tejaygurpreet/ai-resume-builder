# Database
DATABASE_URL="postgresql://user:password@localhost:5432/ai_resume_builder"

# NextAuth
NEXTAUTH_SECRET="generate-a-random-secret"
NEXTAUTH_URL="http://localhost:3000"

# OpenAI
OPENAI_API_KEY="sk-your-openai-api-key"

# Stripe (all required for full payment support)
STRIPE_SECRET_KEY="sk_test_your-stripe-secret-key"
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_your-stripe-publishable-key"
STRIPE_WEBHOOK_SECRET="whsec_your-webhook-secret"

# Stripe Price IDs (create products in Stripe Dashboard)
STRIPE_PRO_PRICE_ID="price_xxx"           # Pro Monthly $7.99/month
STRIPE_PRO_ANNUAL_PRICE_ID="price_xxx"   # Pro Annual $69.99/year
STRIPE_PRO_LIFETIME_PRICE_ID="price_xxx" # Pro Lifetime $129.99 one-time
STRIPE_ONE_TIME_PRICE_ID="price_xxx"     # One-Time Export $19.99
