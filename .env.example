# Database
DATABASE_URL="postgresql://user:password@localhost:5432/ai_resume_builder"

# NextAuth
NEXTAUTH_SECRET="generate-a-random-secret"
NEXTAUTH_URL="http://localhost:3000"
# Optional: public URL for emails/links if different from NEXTAUTH_URL (production: https://optimacv.io)
# NEXT_PUBLIC_APP_URL="https://optimacv.io"

# OpenAI
OPENAI_API_KEY="sk-your-openai-api-key"

# Resend (contact form + password reset) — required for forgot-password / contact
RESEND_API_KEY="re_your-resend-api-key"
SUPPORT_EMAIL="support@optimacv.io"
# Contact form notifications (default in code: tejaygurpreett@icloud.com if unset)
CONTACT_FORM_TO="tejaygurpreett@icloud.com"
# Optional: From line for contact + autoresponse (must be a verified sender/domain in Resend)
# CONTACT_FROM="OptimaCV Contact <support@optimacv.io>"
# Physical / mailing address shown in transactional email footers (CAN-SPAM / trust). Use \n for line breaks.
# COMPANY_LEGAL_ADDRESS="OptimaCV\n123 Main St\nCity, ST 12345\nUnited States"
# From address — must match a verified domain/sender in Resend (SPF/DKIM in DNS per dashboard).
# If unset, code defaults to OptimaCV Support <support@optimacv.io>.
# RESEND_FROM="OptimaCV Support <support@optimacv.io>"
# For Resend sandbox only (limited recipients): RESEND_FROM="OptimaCV <onboarding@resend.dev>"
# Password reset link lifetime (hours, default 24, max 168)
# PASSWORD_RESET_EXPIRY_HOURS="24"

# Optional: POST /api/test-email (production requires header x-test-email-secret)
# TEST_EMAIL_SECRET="long-random-string"
# TEST_EMAIL_TO="you@example.com"

# Stripe (all required for full payment support)
STRIPE_SECRET_KEY="sk_test_your-stripe-secret-key"
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_your-stripe-publishable-key"
STRIPE_WEBHOOK_SECRET="whsec_your-webhook-secret"

# Stripe Price IDs (create matching products/prices in Stripe Dashboard)
STRIPE_PRO_MONTHLY_PRICE_ID="price_xxx_pro_monthly"   # Pro $9.99/month (preferred)
STRIPE_PRO_ANNUAL_PRICE_ID="price_xxx_pro_annual"     # Pro $79.99/year
STRIPE_LIFETIME_PRICE_ID="price_xxx_lifetime"            # Pro Lifetime $199.99 (preferred)
STRIPE_PRO_LIFETIME_PRICE_ID="price_xxx_lifetime"      # alias of STRIPE_LIFETIME_PRICE_ID
STRIPE_EXPORT_PRICE_ID="price_xxx_export_access"       # Export Access $29.99 one-time
# Legacy fallbacks (optional if you still use old env names in hosting)
# STRIPE_PRO_PRICE_ID — same as STRIPE_PRO_MONTHLY_PRICE_ID
# STRIPE_ONE_TIME_PRICE_ID — same as STRIPE_EXPORT_PRICE_ID

# Stripe success/cancel URLs (optional; defaults from NEXTAUTH_URL)
STRIPE_SUCCESS_URL="https://optimacv.io/dashboard?success=true"
STRIPE_CANCEL_URL="https://optimacv.io/pricing?canceled=true"
