# Database
DATABASE_URL="postgresql://user:password@localhost:5432/ai_resume_builder"

# NextAuth
NEXTAUTH_SECRET="generate-a-random-secret"
NEXTAUTH_URL="http://localhost:3000"
# Optional: public URL for emails/links if different from NEXTAUTH_URL (production: https://optimacv.io)
# NEXT_PUBLIC_APP_URL="https://optimacv.io"

# OpenAI
OPENAI_API_KEY="sk-your-openai-api-key"

# Resend (contact form + password reset) — required for forgot-password / contact
RESEND_API_KEY="re_your-resend-api-key"
SUPPORT_EMAIL="support@optimacv.io"
# Contact form notifications (default in code: tejaygurpreett@icloud.com if unset)
CONTACT_FORM_TO="tejaygurpreett@icloud.com"
# Optional: From line for contact + autoresponse (must be a verified sender/domain in Resend)
# CONTACT_FROM="OptimaCV Contact <support@optimacv.io>"
# Physical / mailing address shown in transactional email footers (CAN-SPAM / trust). Use \n for line breaks.
# COMPANY_LEGAL_ADDRESS="OptimaCV\n123 Main St\nCity, ST 12345\nUnited States"
# From address — must match a verified domain/sender in Resend (SPF/DKIM in DNS per dashboard).
# If unset, code defaults to OptimaCV Support <support@optimacv.io>.
# RESEND_FROM="OptimaCV Support <support@optimacv.io>"
# For Resend sandbox only (limited recipients): RESEND_FROM="OptimaCV <onboarding@resend.dev>"
# Password reset link lifetime (hours, default 24, max 168)
# PASSWORD_RESET_EXPIRY_HOURS="24"

# Optional: POST /api/test-email (production requires header x-test-email-secret)
# TEST_EMAIL_SECRET="long-random-string"
# TEST_EMAIL_TO="you@example.com"

# ─── Stripe (NODE_ENV selects test vs live) ─────────────────────────────────
# Development (NODE_ENV !== production): STRIPE_TEST_* + STRIPE_TEST_SECRET_KEY
# Production: STRIPE_LIVE_* + STRIPE_LIVE_SECRET_KEY
# Optional fallback for either: STRIPE_SECRET_KEY, STRIPE_WEBHOOK_SECRET, NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY

# Secret keys (required per environment you run)
STRIPE_TEST_SECRET_KEY="sk_test_…"
STRIPE_LIVE_SECRET_KEY="sk_live_…"
# Optional single-key fallback (e.g. local dev with one key only)
# STRIPE_SECRET_KEY="sk_test_…"

# Publishable keys for Stripe.js / Elements (NEXT_PUBLIC_* required in browser)
NEXT_PUBLIC_STRIPE_TEST_PUBLISHABLE_KEY="pk_test_…"
NEXT_PUBLIC_STRIPE_LIVE_PUBLISHABLE_KEY="pk_live_…"
# Optional aliases:
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY_TEST / NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY_LIVE
# Legacy single key:
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_…"

# Webhook signing secrets (match Dashboard endpoint for test vs live)
STRIPE_TEST_WEBHOOK_SECRET="whsec_…"
STRIPE_LIVE_WEBHOOK_SECRET="whsec_…"
# Legacy:
# STRIPE_WEBHOOK_SECRET="whsec_…"

# Pro prices — test mode (development)
STRIPE_TEST_PRO_MONTHLY_PRICE_ID="price_…"
STRIPE_TEST_PRO_ANNUAL_PRICE_ID="price_…"
STRIPE_TEST_PRO_LIFETIME_PRICE_ID="price_…"
STRIPE_TEST_EXPORT_PRICE_ID="price_…"

# Pro prices — live mode (production)
STRIPE_LIVE_PRO_MONTHLY_PRICE_ID="price_…"
STRIPE_LIVE_PRO_ANNUAL_PRICE_ID="price_…"
STRIPE_LIVE_PRO_LIFETIME_PRICE_ID="price_…"
STRIPE_LIVE_EXPORT_PRICE_ID="price_…"

# Legacy shared IDs (used if mode-specific ID missing)
# STRIPE_PRO_MONTHLY_PRICE_ID / STRIPE_PRO_PRICE_ID
# STRIPE_PRO_ANNUAL_PRICE_ID
# STRIPE_LIFETIME_PRICE_ID / STRIPE_PRO_LIFETIME_PRICE_ID
# STRIPE_EXPORT_PRICE_ID / STRIPE_ONE_TIME_PRICE_ID

# Upgrades: if DB may contain subscriptions from both Stripe accounts, set BOTH secret keys above.
# Subscription ids are always `sub_…` (Stripe does not use sub_test_).

# Stripe success/cancel URLs (optional; defaults from NEXTAUTH_URL)
STRIPE_SUCCESS_URL="https://optimacv.io/dashboard?success=true"
STRIPE_CANCEL_URL="https://optimacv.io/pricing?canceled=true"
