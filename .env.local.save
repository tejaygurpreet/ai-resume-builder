# Stripe (add your live keys)
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_xxxxxxxxx
STRIPE_SECRET_KEY="whsec_xxxxxxxxxxxxxxxx"

# Stripe Price IDs (from Stripe Dashboard)
STRIPE_PRO_PRICE_ID=price_xxx_monthly
STRIPE_PRO_ANNUAL_PRICE_ID=price_xxx_annual
STRIPE_PRO_LIFETIME_PRICE_ID=price_xxx_lifetime
STRIPE_ONE_TIME_PRICE_ID=price_xxx_export

# Stripe Webhook (for production)
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxx

# Stripe success/cancel URLs (optional; defaults from NEXTAUTH_URL)
STRIPE_SUCCESS_URL=https://optimacv.io/dashboard?success=true
STRIPE_CANCEL_URL=https://optimacv.io/pricing?canceled=true
